{
  "expo": {
    "name": "brincalibras",
    "slug": "brincalibras-sprint1",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "brincalibras",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.gustavoassissantos1.brincalibrassprint1"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "915051cf-b013-4dd7-b0ba-207d1b2de957"
      }
    }
  }
}
